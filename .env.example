# RetailIQ — 環境變數範本
# 複製為 .env 並填入實際值（.env 已在 .gitignore，不會 commit）
#
# 使用方式：
#   cp .env.example .env
#   # 編輯 .env，填入 OPENAI_API_KEY
#   source .env   # 或讓你的 shell 自動載入

# ──────────────────────────────────────────────────────
# LLM — OpenAI API（預設）
# ──────────────────────────────────────────────────────

# OpenAI API key（必填，打 api.openai.com 時需要）
export OPENAI_API_KEY=sk-...

# API endpoint（預設 api.openai.com；本地 Ollama 改為 http://localhost:11434/v1）
export OPENAI_ENDPOINT=https://api.openai.com/v1

# Chat model（Gate 3 rubric 打分 + Gate 4 ingest）
export OPENAI_CHAT_MODEL=gpt-4o-mini

# Embedding model（Gate 1b 近重偵測）
export OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 請求 timeout（秒）
export OPENAI_TIMEOUT=30

# ──────────────────────────────────────────────────────
# 測試 / CI
# ──────────────────────────────────────────────────────

# 設為 1 時使用內建 MockLLMClient，不打網路（CI / unit test 用）
# export OPENAI_MOCK=1
